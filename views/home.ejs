<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('./partials/head') %>
    <title>Home Page</title>
</head>

<body>
    <%- include('./partials/navbar') %>

    <%- include('./partials/money_spent') %>



    <div class="container mt-4">
    <div class="card shadow">
        <div class="card-body">

        <h4 class="mb-3">Your Bills</h4>

        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Purpose</th>
                <th>Amount (₹)</th>
                <th>Date</th>
                <th>Action</th>
            </tr>
            </thead>

            <tbody>
            <% if (bill.length === 0) { %>
                <tr>
                <td colspan="5" class="text-center">No bills added yet</td>
                </tr>
            <% } %>

            <% bill.forEach((bill, index) => { %>
                <tr>
                <td><%= index + 1 %></td>
                <td><%= bill.purpose %></td>
                <td>₹ <%= bill.amount %></td>
                <td><%= new Date(bill.date).toLocaleDateString() %></td>
                <td><form action="/bill/delete/<%= bill._id %>" method="post"><button type="submit">Delete</button></form></td>
                </tr>
            <% }) %>
            </tbody>
        </table>

        </div>
    </div>

    </div>


   <%- include('./partials/script') %>
</body>
</html>